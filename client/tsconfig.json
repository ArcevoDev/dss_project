{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",

    "jsx": "react-jsx",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "types": [
      "vite/client"
    ],

    "paths": {
      "@/*": [
        "./src/*"
      ],

      "@styles/*": [
        "./src/styles/*"
      ]
    }
  },

  "include": [
    "src",
    "vite.config.ts"
  ],

  "exclude": [
    "dist",
    "node_modules"
  ]
}