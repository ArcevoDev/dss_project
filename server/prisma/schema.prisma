// ============================================================================
// DSS — Weighted Decision Support System for Subject Combination & Career
// Path Selection (Nigerian SS2 students, 2025/2026 NERDC Curriculum).
//
// PRISMA 7 NOTICE: datasource intentionally carries NO `url` field.
// Connection strings live exclusively in server/prisma.config.ts and are
// injected at runtime. This is a hard Prisma 7 architectural requirement,
// not a style choice. See server/prisma.config.ts and server/src/db/prisma.ts
//
// DESIGN PRINCIPLES
// ─────────────────
// 1. Fully normalized — subjects are rows in SubjectScore, not columns.
//    Adding a new NERDC subject is an INSERT, never an ALTER TABLE.
// 2. Every recommendation is fully auditable — the exact weights and inputs
//    that produced each recommendation are stored alongside the output
//    (Explainability Gap, §2.6 / NFR-01).
// 3. Raw psychometric responses (RIASEC + BFI) are persisted separately
//    from derived profiles to support re-scoring, research validity checks,
//    and the thesis's 100-profile simulation (§3.8 Validation Testing).
// 4. Stakeholder roles (Student, Counselor, School, Admin) are modelled as
//    first-class entities per §1.6 Significance of the Study.
// 5. JAMB catalog is relational — mandatory subjects are rows in
//    JambCourseSubject, not a PostgreSQL ARRAY, enabling proper JOINs and
//    prerequisite validation (FR-08).
//
// VALIDATION SOURCE OF TRUTH
// ───────────────────────────
// Zod validators in src/validators/ import Prisma's own generated enums
// (e.g. `Subject`, `Gender`) from the client output below and build
// `z.enum(...)` schemas directly off `Object.values(...)`, so enum drift is
// structurally impossible — adding a value here updates the validator with
// zero hand-edits. Field-level constraints (lengths, ranges) are kept
// adjacent to the corresponding model with a comment back to this file.
// We deliberately do NOT use a Prisma→Zod model generator (e.g.
// prisma-zod-generator): as of writing it has an open bug that corrupts
// prisma-client's client.ts output when both generators share Prisma 7's
// new generator pipeline, and its exact Prisma-7 export naming isn't
// independently confirmable from current docs. Deriving from the client's
// own enums gets most of the same drift-protection with no such risk.
// ============================================================================

generator client {
  provider               = "prisma-client"
  output                 = "./generated"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum SSLevel {
  SS1
  SS2
  SS3
}

/// The three academic streams a Nigerian SS student can be placed into.
/// Science → Biology/Chemistry/Physics combinations.
/// Humanities → Literature/Government/History/CRS combinations.
/// Business → Economics/Commerce/Accounting combinations.
enum AcademicStream {
  SCIENCE
  HUMANITIES
  BUSINESS
}

/// Holland's RIASEC vocational personality typology (§2.3.1).
/// R = Realistic  I = Investigative  A = Artistic
/// S = Social     E = Enterprising   C = Conventional
enum RiasecType {
  R
  I
  A
  S
  E
  C
}

/// Big Five personality traits used in BFI-20 (§3.5.3).
enum PersonalityTrait {
  O // Openness
  C // Conscientiousness
  E // Extraversion
  A // Agreeableness
  N // Neuroticism
}

/// Role-based access. Four stakeholder classes per §1.6.
enum UserRole {
  STUDENT
  COUNSELOR
  SCHOOL_ADMIN
  ADMIN
}

/// Academic level at which a subject score was recorded.
/// JSS3 contributes 40 % of the weighted academic score.
/// SS1 contributes 60 % (§3.5.3 Phase 2 normalization).
enum AcademicLevel {
  JSS3
  SS1
}

/// Nigerian Senior Secondary curriculum subjects, covering all streams
/// recognized under WAEC / NECO / NERDC 2025/2026.
///
/// NERDC 2025 compulsory core: ENGLISH_LANGUAGE, MATHEMATICS,
/// CITIZENSHIP_AND_HERITAGE, DIGITAL_TECHNOLOGIES + one TRADE_SUBJECT.
/// Stream-specific and elective subjects follow below.
enum Subject {
  // ── COMPULSORY CORE (all students, NERDC 2025/2026) ──────────────────────
  ENGLISH_LANGUAGE
  MATHEMATICS
  CITIZENSHIP_AND_HERITAGE // replaces Civic Education / Social Studies
  DIGITAL_TECHNOLOGIES // new NERDC 2025 core requirement

  // ── SCIENCE STREAM ───────────────────────────────────────────────────────
  BIOLOGY
  CHEMISTRY
  PHYSICS
  FURTHER_MATHEMATICS
  AGRICULTURAL_SCIENCE
  ANIMAL_HUSBANDRY
  TECHNICAL_DRAWING
  FOOD_AND_NUTRITION // can appear in Science or Humanities
  HOME_MANAGEMENT

  // ── HUMANITIES STREAM ────────────────────────────────────────────────────
  LITERATURE_IN_ENGLISH
  GOVERNMENT
  HISTORY
  GEOGRAPHY
  CHRISTIAN_RELIGIOUS_STUDIES
  ISLAMIC_RELIGIOUS_STUDIES
  FRENCH
  YORUBA
  IGBO
  HAUSA
  ARABIC
  VISUAL_ARTS
  MUSIC
  SOCIAL_STUDIES // retained for JSS3 baseline input

  // ── BUSINESS / COMMERCIAL STREAM ─────────────────────────────────────────
  ECONOMICS
  COMMERCE
  FINANCIAL_ACCOUNTING
  BOOK_KEEPING
  MARKETING
  OFFICE_PRACTICE
  STORE_MANAGEMENT
  DATA_PROCESSING
  BUSINESS_STUDIES // retained for JSS3 baseline input

  // ── VOCATIONAL TRADE SUBJECTS (NERDC 2025 — pick one) ────────────────────
  TRADE_WOODWORK
  TRADE_METALWORK
  TRADE_ELECTRONICS
  TRADE_AUTO_MECHANICS
  TRADE_COSMETOLOGY
  TRADE_CATERING_CRAFT
  TRADE_GARMENT_MAKING
  TRADE_PLUMBING
  TRADE_BUILDING_CONSTRUCTION
  TRADE_COMPUTER_CRAFT

  // ── GENERAL / CROSS-STREAM ───────────────────────────────────────────────
  BASIC_SCIENCE // JSS3 baseline only; not WAEC-entered
  CIVIC_EDUCATION // legacy; superseded by CITIZENSHIP_AND_HERITAGE
  COMPUTER_STUDIES
}

// ─────────────────────────────────────────────────────────────────────────────
// INSTITUTIONS
// ─────────────────────────────────────────────────────────────────────────────

/// A secondary school that can host multiple students and counselors.
/// Supports the multi-school deployment scenario (§1.6 Schools stakeholder).
model School {
  id         String  @id @default(uuid())
  name       String
  state      String?
  lga        String? // Local Government Area
  schoolType String? // "Public" | "Private" | "Federal Unity College"
  address    String?

  students   Student[]
  counselors Counselor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, state])
  @@index([state])
  @@map("schools")
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE IDENTITY — STUDENT
// ─────────────────────────────────────────────────────────────────────────────

/// Primary actor of the DSS (FR-01).
/// All psychometric and academic data hangs off this record.
model Student {
  id           String    @id @default(uuid())
  fullName     String
  gender       Gender    @default(UNSPECIFIED)
  dateOfBirth  DateTime?
  email        String    @unique
  passwordHash String
  role         UserRole  @default(STUDENT)
  ssLevel      SSLevel   @default(SS2)
  phoneNumber  String?

  /// Optional link to a School entity (multi-school deployments).
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  /// Optional link to an assigned guidance counselor (§1.6).
  counselorId String?
  counselor   Counselor? @relation(fields: [counselorId], references: [id], onDelete: SetNull)

  /// Career aspiration as free text — used by the JAMB validator (FR-08).
  /// E.g. "Medicine and Surgery", "Law", "Accounting".
  careerAspiration String?

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  academicProfile    AcademicProfile?
  subjectScores      SubjectScore[]
  riasecProfile      RiasecProfile?
  riasecResponses    RiasecResponse[]
  personalityProfile PersonalityProfile?
  bfiResponses       BfiResponse[]
  recommendations    RecommendationLog[]
  jambValidations    JambValidation[]
  auditLogs          AuditLog[]

  @@index([schoolId])
  @@index([counselorId])
  @@index([email])
  @@map("students")
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE IDENTITY — COUNSELOR
// ─────────────────────────────────────────────────────────────────────────────

/// Guidance counselor — stakeholder class per §1.6.
/// Assigned students can be reviewed via the counselor dashboard.
model Counselor {
  id            String   @id @default(uuid())
  fullName      String
  email         String   @unique
  passwordHash  String
  phone         String?
  qualification String? // e.g. "B.Ed Guidance & Counselling"
  role          UserRole @default(COUNSELOR)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  students Student[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@map("counselors")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACADEMIC PROFILE (FR-02)
// ─────────────────────────────────────────────────────────────────────────────

/// Aggregate academic record for a student.
/// The weighted academic score formula per §3.5.3:
///   weightedAcademicScore = (jss3Average × 0.40) + (ss1Average × 0.60)
///
/// Individual subject scores live in SubjectScore — fully normalized so
/// that any subject (including new NERDC trade subjects) can be added
/// without a schema migration.
model AcademicProfile {
  id        String  @id @default(uuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// Simple averages computed from SubjectScore rows at submission time.
  /// Stored (not just computed) so recommendation logs can be fully
  /// self-contained even if scores are later corrected (Explainability Gap).
  jss3Average Float @default(0)
  ss1Average  Float @default(0)

  /// ω₁ input: (jss3Average × 0.40) + (ss1Average × 0.60) / 100
  /// Normalized to [0, 1] before SAW aggregation (§3.5.3).
  weightedAcademicScore Float @default(0)

  /// Name of the NERDC 2025 trade subject chosen (if any).
  /// Score stored in SubjectScore with subject = TRADE_* variant.
  tradeSubjectChosen Subject?

  recordedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("academic_profiles")
}

/// Normalized subject scores. One row per (student, subject, level).
/// This replaces the flat columns ss1English, ss1Mathematics, etc.
///
/// Adding a new NERDC subject in a future curriculum revision is a new
/// enum value + new data rows — zero DDL changes required.
model SubjectScore {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subject Subject
  level   AcademicLevel // JSS3 or SS1
  score   Float // raw percentage 0–100

  recordedAt DateTime @default(now())

  @@unique([studentId, subject, level])
  @@index([studentId])
  @@index([subject])
  @@map("subject_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// RIASEC VOCATIONAL INTEREST PROFILE (FR-03)
// ─────────────────────────────────────────────────────────────────────────────

/// Derived RIASEC profile — computed from 48 RiasecResponse items (FR-03).
/// Stream affinities map to SAW criterion C₂ (ω₂ = 0.297, §3.5.2):
///   scienceAffinity     = normalized(I + R scores)
///   humanitiesAffinity  = normalized(A + S scores)
///   businessAffinity    = normalized(E + C scores)
model RiasecProfile {
  id        String  @id @default(uuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  rScore Float @default(0) // Realistic
  iScore Float @default(0) // Investigative
  aScore Float @default(0) // Artistic
  sScore Float @default(0) // Social
  eScore Float @default(0) // Enterprising
  cScore Float @default(0) // Conventional

  /// Holland three-letter summary code, e.g. "ISR", "ECR".
  summaryCode String @default("")

  /// Pre-computed stream affinities (normalized 0–1), used directly in
  /// the SAW scoring step without re-querying response rows each time.
  scienceAffinity    Float @default(0) // (I + R) / maxCombinedScore
  humanitiesAffinity Float @default(0) // (A + S) / maxCombinedScore
  businessAffinity   Float @default(0) // (E + C) / maxCombinedScore

  assessedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("riasec_profiles")
}

/// Raw per-item RIASEC responses (48 items, Likert 1–5).
/// Retained for re-scoring, audit, and the 100-profile validation study (§3.8).
model RiasecResponse {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  questionId Int // 1–48, maps to the validated RIASEC instrument
  type       RiasecType // R | I | A | S | E | C
  value      Int // Likert 1–5

  createdAt DateTime @default(now())

  @@unique([studentId, questionId])
  @@index([studentId])
  @@map("riasec_responses")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERSONALITY — BIG FIVE INVENTORY (BFI-20) (§3.5.3)
// ─────────────────────────────────────────────────────────────────────────────

/// Derived Big Five personality profile — criterion C₃ (ω₃ = 0.163, §3.5.2).
/// Each trait score is normalized to [0, 100] before SAW aggregation.
///
/// Stream-personality mappings used in recommendation logic:
///   Science    → high Openness (O)
///   Humanities → high Openness (O) + Agreeableness (A)
///   Business   → high Conscientiousness (C) + Extraversion (E)
model PersonalityProfile {
  id        String  @id @default(uuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  opennessScore          Float @default(0) // normalized 0–100
  conscientiousnessScore Float @default(0)
  extraversionScore      Float @default(0)
  agreeablenessScore     Float @default(0)
  neuroticismScore       Float @default(0)

  assessedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("personality_profiles")
}

/// Raw per-item BFI-20 responses (20 items, Likert 1–5).
/// reverseKeyed = true means the item must be reverse-scored before
/// computing the trait sub-total.
model BfiResponse {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  questionId   Int // 1–20, maps to the BFI-20 instrument
  trait        PersonalityTrait
  reverseKeyed Boolean          @default(false)
  value        Int // Likert 1–5 (raw, before any reversal)

  createdAt DateTime @default(now())

  @@unique([studentId, questionId])
  @@index([studentId])
  @@map("bfi_responses")
}

// ─────────────────────────────────────────────────────────────────────────────
// RECOMMENDATION ENGINE OUTPUT (FR-05 / FR-06 / FR-07)
// ─────────────────────────────────────────────────────────────────────────────

/// Immutable record of one recommendation run (AHP-SAW engine output).
///
/// AUDITABILITY (NFR-01 / §2.6 Explainability Gap):
/// Every field that fed into this recommendation is snapshotted here so
/// that if the student's profile is later updated the historical result
/// remains fully traceable. Nothing here references live profile rows —
/// it is a complete self-contained record of what was computed and why.
model RecommendationLog {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  /// AHP-SAW outputs (§3.5.4)
  topStream   AcademicStream
  vScience    Float // SAW Vᵢ for SCIENCE   (0–1)
  vHumanities Float // SAW Vᵢ for HUMANITIES (0–1)
  vBusiness   Float // SAW Vᵢ for BUSINESS  (0–1)

  /// Confidence Level (§3.5.4): CL = (V_max / ΣVᵢ) × 100, then rescaled.
  confidenceLevel Float

  /// Plain-language explanation referencing the student's dominant scores
  /// (FR-07 Guidance Insights / NFR-01 Explainability).
  guidanceInsight String @db.Text

  /// Full snapshot of AHP criterion weights used (CR must be ≤ 0.10).
  /// Stored as JSON so future weight recalibrations don't invalidate
  /// historical records.
  /// Shape: { w1_academic: 0.540, w2_riasec: 0.297, w3_personality: 0.163, cr: 0.007 }
  ahpWeightsSnapshot Json

  /// Complete snapshot of all normalized inputs used by SAW (§3.5.3).
  /// Shape: {
  ///   academicScore: 0.72,
  ///   riasecScience: 0.76, riasecHumanities: 0.40, riasecBusiness: 0.30,
  ///   personalityScience: 0.68, personalityHumanities: 0.55, personalityBusiness: 0.50,
  ///   jss3Average: 65, ss1Average: 76, weightedAcademicScore: 71.6
  /// }
  inputsSnapshot Json

  /// Algorithm version string (e.g. "ahp-saw-v1.0") — supports future
  /// engine updates while preserving comparability of old logs.
  algorithmVersion String @default("ahp-saw-v1.0")

  generatedAt DateTime @default(now())

  @@index([studentId])
  @@index([generatedAt])
  @@map("recommendation_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// JAMB CATALOG (FR-08)
// ─────────────────────────────────────────────────────────────────────────────

/// A tertiary degree programme with JAMB O'Level subject prerequisites.
/// Replaces the previous `mandatorySubjects String[]` ARRAY with a proper
/// relational join table (JambCourseSubject), enabling clean prerequisite
/// queries and compliance validation.
model JambCourse {
  id             String         @id @default(uuid())
  courseName     String         @unique
  facultyArea    String // e.g. "Medicine", "Law", "Engineering"
  streamCategory AcademicStream
  utmeCutoffHint Int? // indicative UTME score (not enforced)
  description    String         @default("") @db.Text

  mandatorySubjects JambCourseSubject[]
  validations       JambValidation[]

  updatedAt DateTime @default(now()) @updatedAt
  createdAt DateTime @default(now())

  @@index([streamCategory])
  @@index([facultyArea])
  @@map("jamb_courses")
}

/// Join table: which subjects are mandatory for a given JAMB course.
/// Replaces the String[] array for full relational query support.
model JambCourseSubject {
  id           String     @id @default(uuid())
  jambCourseId String
  jambCourse   JambCourse @relation(fields: [jambCourseId], references: [id], onDelete: Cascade)

  subject Subject // e.g. BIOLOGY, CHEMISTRY, PHYSICS for Medicine

  @@unique([jambCourseId, subject])
  @@index([jambCourseId])
  @@map("jamb_course_subjects")
}

/// FR-08: JAMB prerequisite validation result.
/// Stores the output of cross-referencing a student's recommended stream
/// and subjects against JAMB's published requirements for their stated
/// career aspiration.
model JambValidation {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  jambCourseId String
  jambCourse   JambCourse @relation(fields: [jambCourseId], references: [id], onDelete: Cascade)

  recommendedStream AcademicStream
  isCompliant       Boolean // true = prerequisites satisfied
  missingSubjects   Subject[] // populated if isCompliant = false
  validationNotes   String?        @db.Text

  validatedAt DateTime @default(now())

  @@index([studentId])
  @@index([jambCourseId])
  @@map("jamb_validations")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG (NFR-05 Security)
// ─────────────────────────────────────────────────────────────────────────────

/// Lightweight, append-only accountability trail.
/// Generic enough to cover any actor / resource / action combination.
/// studentId is nullable to support admin and counselor actions where
/// no student is the subject.
model AuditLog {
  id        String   @id @default(uuid())
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  /// Actor performing the action (may differ from studentId for counselor/admin ops).
  actorId   String?
  actorRole UserRole?

  /// Coarse action category. Recommended values:
  /// LOGIN | LOGOUT | PASSWORD_CHANGE
  /// SCORES_SUBMITTED | RIASEC_COMPLETED | BFI_COMPLETED
  /// RECOMMENDATION_GENERATED | JAMB_VALIDATED
  /// PROFILE_UPDATED | ACCOUNT_DEACTIVATED
  action String

  /// Arbitrary structured payload — keeps the table generic while
  /// allowing rich event-specific data to be stored.
  metadata Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}