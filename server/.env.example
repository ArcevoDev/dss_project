# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL connection (local Postgres on your machine)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Used by:
#  - prisma.config.ts  (CLI: migrate, studio, db seed)
#  - src/db/prisma.ts  (running app, via @prisma/adapter-pg)
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://arcevodev:%407c3v0d3v@127.0.0.1:5432/dss_project?schema=public

# ─────────────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────────────
JWT_SECRET="change_this_to_a_long_random_string_in_production"
JWT_EXPIRES_IN="7d"

# ─────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# CORS — must match the Vite client origin
CLIENT_URL="http://localhost:5173"
