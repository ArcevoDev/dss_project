{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@prisma-client": ["./prisma/generated/client"]
    }
  },
  "include": ["src/**/*.ts", "prisma/generated/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}