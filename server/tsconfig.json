{
  "extends": "../tsconfig.base.json",

  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "lib": ["ES2022"],
    "types": ["node"],

    "paths": {
      "@/*": ["./src/*"],
      "@prisma-client": [
        "./prisma/generated/client"
      ]
    }
  },

  "include": ["src/**/*.ts", "prisma/**/*.ts", "prisma.config.ts"],

  "exclude": ["dist", "node_modules"]
}